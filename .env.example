# Скопіюй у .env і заповни значення. Файл .env у репозиторій не потрапляє.

PORT=3001
FASTAPI_URL=http://127.0.0.1:8000/api/ingest/whatsapp
SOURCE_CHAT=
TARGET_CHAT=
# Режим лише .env (без flows.json): фільтри по тексту повідомлення. Якщо обидва порожні — усе пропускається (як *).
SOURCE_FILTER_KEYWORDS=
SOURCE_FILTER_FREQUENCIES=
SEND_PREFIX=#go
SEND_DELAY_MS=2000
HEADLESS=1

# Панель керування (якщо обидва задані — вхід обовʼязковий, інакше панель відкрита)
PANEL_USER=user
PANEL_PASSWORD=772132

# Signal transport bridge (expected endpoints: GET /chats, GET /messages, POST /send)
SIGNAL_API_URL=http://localhost:3002
SIGNAL_POLL_MS=5000

# Номер телефону Signal-акаунта, зареєстрованого в signal-cli-api (з +)
# Використовується в docker-compose.signal.yml через ${SIGNAL_ACCOUNT_NUMBER}
SIGNAL_ACCOUNT_NUMBER=+380XXXXXXXXX

